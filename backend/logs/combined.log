{"level":"debug","message":"Executing (default): SELECT medicineId, SUM(inwardQty) - SUM(outwardQty) as openingQty\n      FROM (\n        SELECT pit.medicineId, (pit.qty + IFNULL(pit.freeQty, 0)) as inwardQty, 0 as outwardQty\n        FROM purchase_items pit\n        JOIN purchase_invoices pi ON pit.purchaseId = pi.id\n        WHERE pi.isDeleted = 0 AND pi.status = 'completed' AND pi.invoiceDate < '2026-07-01'\n\n        UNION ALL\n\n        SELECT sit.medicineId, 0 as inwardQty, (sit.qty + IFNULL(sit.free, 0)) as outwardQty\n        FROM sale_items sit\n        JOIN sale_invoices si ON sit.saleId = si.id\n        WHERE si.isDeleted = 0 AND si.status = 'completed' AND si.invoiceDate < '2026-07-01'\n\n        UNION ALL\n\n        SELECT sa.medicineId, \n          IF(sa.adjustmentType = 'increase', sa.qty, 0) as inwardQty,\n          IF(sa.adjustmentType IN ('decrease', 'damage', 'transfer'), sa.qty, 0) as outwardQty\n        FROM stock_adjustments sa\n        WHERE sa.isDeleted = 0 AND sa.date < '2026-07-01'\n      ) as all_tx\n      GROUP BY medicineId","timestamp":"2026-07-01 12:28:27"}
